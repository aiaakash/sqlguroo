ANALYTICS_ENCRYPTION_KEY=
CREDS_IV=
CREDS_KEY=
DOMAIN_CLIENT=https://sqlguroo.com
DOMAIN_SERVER=https://sqlguroo.com
FILE_UPLOAD_SIZE_LIMIT=10485760
HOST=0.0.0.0
JWT_REFRESH_SECRET=
JWT_SECRET=
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=
MONGO_URI=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@mongodb:27017/LibreChat?authSource=admin
NODE_ENV=production
PORT=3080
RAG_PORT=8000
RAG_API_URL=http://rag_api:8000

# RAG API Configuration - Using OpenRouter for embeddings (to avoid OpenAI quota limits)
RAG_OPENAI_BASEURL=https://openrouter.ai/api/v1
RAG_OPENAI_API_KEY=
REDIS_URI=redis://localhost:6379
REDIS_CLUSTER=true                                        # If using Redis cluster
REDIS_TLS=true                                            # If Redis requires TLS
SESSION_SECRET=
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
DEBUG_LOGGING=false                                       # Set to false in production
ERROR_LOGGING=true                                        # Enable error logging
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/oauth/google/callback
ALLOW_SOCIAL_LOGIN=true
ALLOW_SOCIAL_REGISTRATION=true
ALLOW_EMAIL_LOGIN=false
ALLOW_REGISTRATION=false
ALLOW_PASSWORD_RESET=false
ADMIN_EMAILS=

# ==============================================================================
# EDITION CONFIGURATION
# ==============================================================================
# Set to "enterprise" to enable subscription management, query limits, and Paddle payments.
# Set to "community" (default) for unlimited access with no subscription gates.
EDITION=community

# ==============================================================================
# PADDLE PAYMENT GATEWAY (Enterprise Edition Only)
# ==============================================================================
# Only required when EDITION=enterprise
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_CLIENT_TOKEN=
# PADDLE_ENVIRONMENT=sandbox
# PADDLE_PRICE_PRO_MONTHLY=
# PADDLE_PRICE_PRO_ANNUAL=
# PADDLE_PRICE_ULTRA_MONTHLY=
# PADDLE_PRICE_ULTRA_ANNUAL=
ANALYTICS_MAX_SCHEMA_TABLES=15
ANALYTICS_SCHEMA_FILTER_MODEL=xiaomi/mimo-v2-flash
ANALYTICS_SQL_FIX_MODEL=xiaomi/mimo-v2-flash
XAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# Vectordb configuration for skill matching
VECTORDB_HOST=vectordb
VECTORDB_PORT=5432
VECTORDB_DB=mydatabase
VECTORDB_USER=myuser
VECTORDB_PASSWORD=
USE_VECTORDB_FOR_SKILLS=true


# Enable the sample database
SAMPLE_DB_ENABLED=false


EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=openai/text-embedding-3-small

ANALYTICS_EMBEDDING_MODEL=openai/text-embedding-3-small
ANALYTICS_EMBEDDING_DIMENSION=1536


ENDPOINTS=closeAI


# For instant responses (best for production)
CLOSEAI_STREAM_DELAY_MS=3
CLOSEAI_AGENT_EVENT_DELAY_MS=10


# Get 15 candidates from semantic search, LLM picks top 7
ANALYTICS_SEMANTIC_TOP_K=15
ANALYTICS_LLM_MAX_TABLES=7


# Enable hybrid RAG table selection (default: false)
ANALYTICS_USE_HYBRID_TABLE_RAG=true
# Maximum tables to include in schema (default: 15)
#ANALYTICS_MAX_SCHEMA_TABLES=15
# Model for LLM table filtering (default: xiaomi/mimo-v2-flash)
ANALYTICS_TABLE_FILTER_MODEL=xiaomi/mimo-v2-flash